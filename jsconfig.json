{
  "include": ["src/**/*.js", "src/**/*.jsx", "vite.config.js", "eslint.config.js"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "checkJs": false,
    "allowJs": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
